# Production Environment Variables for Backend
# Copy this file to backend/.env and fill in your production values
# 
# IMPORTANT: You also need a root .env file with DB_PASSWORD
# See documentation below for complete setup

# OpenAI API Configuration
OPENAI_API_KEY=sk-your-production-openai-api-key-here
MODEL_NAME=gpt-4o

# JWT Authentication
JWT_SECRET=your-very-secure-random-secret-key-here-use-openssl-rand-base64-32
JWT_ALG=HS256
JWT_EXPIRE_DAYS=7

# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-strong-mysql-password-here
DB_NAME=perspectiveconnect

# MySQL Root Password (must match DB_PASSWORD above)
MYSQL_ROOT_PASSWORD=your-strong-mysql-password-here

# ==============================================================================
# PRODUCTION SETUP INSTRUCTIONS:
# ==============================================================================
# 
# 1. Create /opt/perspectiveconnect/.env (project root):
#    echo "DB_PASSWORD=your-strong-password" > .env
#
# 2. Copy this file to backend/.env:
#    cp .env.production.example backend/.env
#
# 3. Edit backend/.env and set:
#    - All passwords (DB_PASSWORD and MYSQL_ROOT_PASSWORD should match)
#    - OpenAI API key
#    - JWT secret
#
# 4. Make sure both password values are identical in:
#    - /opt/perspectiveconnect/.env (DB_PASSWORD)
#    - /opt/perspectiveconnect/backend/.env (DB_PASSWORD and MYSQL_ROOT_PASSWORD)
#
# ==============================================================================

# Storage
AUDIO_STORAGE_DIR=./app/storage

# Production Settings
# Set this in docker-compose.prod.yml or frontend .env
# NEXT_PUBLIC_API_BASE=https://yourdomain.com/api
